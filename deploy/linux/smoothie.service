[Unit]
Description=Smoothie IPTV/OTA restream layer
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=smoothie
Group=smoothie
Environment=SMOOTHIE_LISTEN=0.0.0.0:8787
Environment=SMOOTHIE_DATA_DIR=/var/lib/smoothie
Environment=SMOOTHIE_DB=/var/lib/smoothie/smoothie.db
ExecStart=/usr/local/bin/smoothie
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
